# =============================================================================
# avp-agent-identity — environment variables
# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to version control.
# =============================================================================

# --- Bitwarden Secrets Manager (bootstrap credentials) ---
# These are the only credentials the app services need at startup.
# All application secrets (API keys, DB passwords) are fetched from BWS
# using these tokens — they do not live in this file.

# Chatbot agent machine account token (chatbot-support)
CHATBOT_BWS_TOKEN=

# SecOps service machine account token (secops-service)
SECOPS_BWS_TOKEN=

# Your Bitwarden organization ID (Settings > Organization ID in the web vault)
BWS_ORGANIZATION_ID=

# --- Amazon Verified Permissions (infrastructure config) ---
# Created by terraform/main.tf — run `terraform apply` first.
AVP_POLICY_STORE_ID=

# --- AWS credentials (used to call AVP IsAuthorized) ---
# Recommend a dedicated IAM user with verifiedpermissions:IsAuthorized only.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Postgres passwords (Docker Compose bootstrap only) ---
# These seed the Postgres containers when they first start.
# They must match the values you stored in BWS under the same key names.
# The app services fetch these from BWS at startup — not from here.
DB_CASES_PASSWORD=
DB_AVAILABILITY_PASSWORD=
DB_INVESTIGATIONS_PASSWORD=
DB_CUSTOMERS_PASSWORD=

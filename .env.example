# =============================================================================
# avp-agent-identity — environment variables
# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to version control.
# =============================================================================

# --- Bitwarden Secrets Manager ---
# The chatbot agent's BWS machine account token.
# This token has access ONLY to the secrets this agent needs.
# Store your personal developer BWS token as a user-level env var, NOT here.
CHATBOT_BWS_TOKEN=

# The SecOps service BWS machine account token.
SECOPS_BWS_TOKEN=

# --- Amazon Verified Permissions ---
# Created by terraform/main.tf — run `terraform apply` first.
AVP_POLICY_STORE_ID=

# --- AWS credentials (used to call AVP IsAuthorized) ---
# Recommend a dedicated IAM user with verifiedpermissions:IsAuthorized only.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Postgres passwords ---
# Used internally by Docker Compose. Pick strong random values.
DB_CASES_PASSWORD=
DB_AVAILABILITY_PASSWORD=
DB_INVESTIGATIONS_PASSWORD=
DB_CUSTOMERS_PASSWORD=

# --- Anthropic ---
# Claude API key for the chatbot agent.
# In production this would be injected by BWS, not stored here.
ANTHROPIC_API_KEY=

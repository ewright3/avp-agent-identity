# =============================================================================
# avp-agent-identity — environment variables
# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to version control.
# =============================================================================

# --- Bitwarden Secrets Manager (bootstrap credentials) ---
# These are the only credentials the services need at startup.
# All application secrets (API keys, DB passwords) are fetched from BWS.

# Chatbot agent machine account token — store in .env.local at project scope
# Your personal developer BWS token belongs in ~/.zshrc, NOT here
CHATBOT_BWS_TOKEN=

# Developer portal machine account token
DEVELOPER_BWS_TOKEN=

# Your Bitwarden organization ID (Settings > Organization ID in the web vault)
BWS_ORGANIZATION_ID=

# --- Amazon Verified Permissions (infrastructure config) ---
# Created by terraform/main.tf — run `terraform apply` first.
AVP_POLICY_STORE_ID=

# --- AWS credentials (used to call AVP IsAuthorized) ---
# Recommend a dedicated IAM user with verifiedpermissions:IsAuthorized only.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Postgres passwords (Docker Compose bootstrap only) ---
# These seed the Postgres containers on first start.
# Values must match what you stored in BWS under the same key names.
# App services fetch these from BWS at startup — not from here.
DB_ORDERS_PASSWORD=
DB_PAYMENTS_PASSWORD=
DB_LOGS_PASSWORD=
